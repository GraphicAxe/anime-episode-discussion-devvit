{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "goodbyelara-bot",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade"
  },
  "scheduler": {
    "tasks": {
      "post-episode-discussion": {
        "endpoint": "/internal/cron/post-episode-discussion",
        "cron": "30 * * * *"
      }
    }
  },
  "settings": {
    "global": {
      "discordWebhook": {
        "type": "string",
        "label": "Discord Webhook URL",
        "helpText": "Optional Discord webhook for success/error notifications.",
        "isSecret": true
      },
      "mockMode": {
        "type": "string",
        "label": "Mock Mode",
        "helpText": "Set to true to use mock metadata for playtest and dry runs instead of live APIs.",
        "defaultValue": "false"
      },
      "apiPlaytestMode": {
        "type": "string",
        "label": "API Playtest Mode",
        "helpText": "Set to true to run an automatic API validation flow on playtest startup (forces Episode 1 then Episode 2).",
        "defaultValue": "false"
      }
    }
  },
  "permissions": {
    "reddit": true,
    "redis": true,
    "http": {
      "enable": true,
      "domains": [
        "api.jikan.moe",
        "graphql.anilist.co",
        "en.wikipedia.org",
        "kitsu.io"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "goodbyelara_bot_dev"
  }
}